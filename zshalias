# Open Claude Code on the NUC in the same path you're standing in locally.
# Spawns a new zellij tab named after the dir, runs `claude`, then drops you
# into the mosh session. Pass an arg to override the path.
mcc() {
  local cwd="${1:-$PWD}"
  local name="${cwd##*/}"
  ssh nuc bash -c "
    export XDG_RUNTIME_DIR=
    zellij --session main action new-tab --cwd '$cwd' --name '$name' 2>/dev/null || true
    sleep 0.2
    zellij --session main action write-chars 'claude' 2>/dev/null
    zellij --session main action write 10 2>/dev/null
  " 2>/dev/null
  mosh nuc
}
{{/if}}
