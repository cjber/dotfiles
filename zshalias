# Open Claude Code on the NUC in the same path you're standing in locally.
# Pushes a one-pane layout, then mosh's a bash that (a) fires zellij
# new-tab and (b) execs into zellij attach IN THE SAME PROCESS — so the
# attaching client inherits the server-side focus set by new-tab and
# lands directly on the just-opened tab. Pass an arg to override the path.
mcc() {
  local cwd="${1:-$PWD}"
  local name="${cwd##*/}"
  local kdl="/tmp/mcc-$$.kdl"
  cat > "$kdl" <<EOF
layout {
    pane cwd="$cwd" command="claude"
}
EOF
  scp -q "$kdl" "nuc:$kdl"
  rm -f "$kdl"
  mosh nuc -- bash -c "
    export XDG_RUNTIME_DIR=
    # Kick other zellij clients + orphaned mosh-servers (newest device wins,
    # matches the zshrc auto-attach behaviour).
    for p in \$(pgrep -u \"\$USER\" -f 'zellij attach' 2>/dev/null); do
      [ \"\$p\" != \"\$\$\" ] && kill -TERM \"\$p\" 2>/dev/null
    done
    for p in \$(pgrep -u \"\$USER\" -f '^mosh-server new' 2>/dev/null); do
      [ \"\$p\" != \"\$PPID\" ] && kill -TERM \"\$p\" 2>/dev/null
    done
    # If main is EXITED-resurrectable, delete it so we can start fresh with
    # the layout. Otherwise --layout would error against the existing entry.
    if zellij list-sessions 2>/dev/null | grep -aq 'main.*EXITED'; then
      zellij delete-session main --force >/dev/null 2>&1
    fi
    # Two paths: active main → action new-tab + attach; no main → -n
    # (new-session-with-layout) which actually creates main from the layout.
    # NB: \`zellij --session main --layout …\` is *attach*-with-extra-tab and
    # errors when main doesn't exist — that's what made bash exit and mosh
    # crash on first run.
    if zellij --session main action new-tab --name '$name' --layout '$kdl' 2>/dev/null; then
      exec zellij attach main
    else
      exec zellij -n '$kdl' -s main
    fi
  "
}
