# Open Claude Code on the NUC in the same path you're standing in locally.
# Pushes a one-pane layout, then mosh's a bash that (a) fires zellij
# new-tab and (b) execs into zellij attach IN THE SAME PROCESS — so the
# attaching client inherits the server-side focus set by new-tab and
# lands directly on the just-opened tab. Pass an arg to override the path.
mcc() {
  local cwd="${1:-$PWD}"
  local name="${cwd##*/}"
  local kdl="/tmp/mcc-$$.kdl"
  cat > "$kdl" <<EOF
layout {
    pane cwd="$cwd" command="claude"
}
EOF
  scp -q "$kdl" "nuc:$kdl"
  rm -f "$kdl"

  # Step 1 (ssh, no TTY needed): ensure main has the claude tab and is
  # focused on it. ssh fires zellij actions; no zellij client attaches.
  ssh nuc bash <<BASH
    export XDG_RUNTIME_DIR=
    if zellij list-sessions 2>/dev/null | grep -aq 'main.*EXITED'; then
      zellij delete-session main --force >/dev/null 2>&1
    fi
    if zellij --session main action new-tab --name '$name' --layout '$kdl' 2>/dev/null; then
      # main was active → focus the new tab so mosh attaches onto it
      zellij --session main action go-to-tab-name '$name' >/dev/null 2>&1
    else
      # main not active → create it fresh from this layout (panics no-TTY
      # client-side, but the server + session + claude pane stay alive)
      zellij -n '$kdl' -s main >/dev/null 2>&1 || true
    fi
BASH

  # Step 2 (mosh, interactive): standard attach via zshrc auto-attach.
  # That gives a real TTY, kicks any lingering client, lands on the
  # tab we focused in step 1.
  mosh nuc
}
