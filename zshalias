# Open Claude Code on the NUC in the same path you're standing in locally.
# Drops a one-pane layout onto the NUC (cwd + `claude` as the pane command),
# tells zellij main to open a new tab with it, then mosh-attaches.
# Pass an arg to override the path.
mcc() {
  local cwd="${1:-$PWD}"
  local name="${cwd##*/}"
  local kdl=/tmp/mcc-$$.kdl
  cat > "$kdl" <<EOF
layout {
    pane cwd="$cwd" {
        command "claude"
    }
}
EOF
  scp -q "$kdl" "nuc:$kdl"
  ssh nuc "XDG_RUNTIME_DIR= zellij --session main action new-tab --name '$name' --layout '$kdl'; rm -f '$kdl'" 2>/dev/null
  rm -f "$kdl"
  mosh nuc
}
{{/if}}
