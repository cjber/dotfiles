sort=-time
layer=overlay
anchor=top-right
background-color=#1e1e2eee
width=350
height=120
margin=10
padding=15
border-size=3
border-color=#89b4fa
border-radius=15
icons=1
max-icon-size=48
icon-location=left
markup=1
actions=1
max-visible=5
default-timeout=5000
ignore-timeout=0
font=JetBrainsMono Nerd Font 11
text-color=#cdd6f4
progress-color=over #89b4fa
group-by=app-name
max-history=20
on-notify=exec mpv /usr/share/sounds/freedesktop/stereo/message.oga --really-quiet

[urgency=low]
border-color=#74c7ec
background-color=#1e1e2ee6
text-color=#bac2de

[urgency=normal]
border-color=#f9e2af
background-color=#1e1e2eee
text-color=#cdd6f4

[urgency=high]
border-color=#f38ba8
background-color=#1e1e2ef5
text-color=#f5e0dc
default-timeout=0

[category=mpd]
default-timeout=2000
group-by=category

[app-name=discord]
border-color=#5865f2
background-color=#5865f233
default-timeout=8000


[app-name=Firefox]
border-color=#ff6611
background-color=#ff661122

[app-name=kitty]
border-color=#a6e3a1
background-color=#1e1e2ef5
font=JetBrainsMono Nerd Font 10

[summary~="^Screenshot"]
border-color=#cba6f7
background-color=#cba6f722
on-notify=exec mpv /usr/share/sounds/freedesktop/stereo/camera-shutter.oga --really-quiet
