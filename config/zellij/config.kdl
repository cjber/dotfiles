theme "oxide"
default_mode "normal"
pane_frames false
mouse_mode true
copy_command "wl-copy"
copy_on_select false
session_serialization true
serialize_pane_viewport true
scrollback_lines_to_serialize 10000
show_startup_tips false
show_release_notes false
mouse_hover_effects false
visual_bell false
stacked_resize true
support_kitty_keyboard_protocol true
simplified_ui true

ui {
    pane_frames {
        rounded_corners false
        hide_session_name false
    }
}

// Narrow-window friendly: default `new pane` always splits down rather than
// zellij's largest-space heuristic (which goes right and crowds the columns).
// Use Ctrl-P r explicitly when you do want a right-split.
keybinds {
    pane {
        bind "n" { NewPane "Down"; SwitchToMode "normal"; }
    }
    shared_except "locked" {
        bind "Alt n" { NewPane "Down"; }
    }
}

plugins {
    compact-bar location="zellij:compact-bar"
    status-bar location="zellij:status-bar"
    tab-bar location="zellij:tab-bar"
    session-manager location="zellij:session-manager"
    plugin-manager location="zellij:plugin-manager"
    configuration location="zellij:configuration"
    about location="zellij:about"
    filepicker location="zellij:strider" { cwd "/"; }
    strider location="zellij:strider"

    zjstatus location="file:/home/cjber/.config/zellij/plugins/zjstatus.wasm" {
        format_left   "#[fg=#e78a53,bold]  {session}  #[fg=#555555]│#[fg=#b0b0b0] {tabs}"
        format_center ""
        format_right  "{mode}#[fg=#555555] │#[fg=#777777] {datetime} "
        format_space  ""
        border_enabled "false"
        hide_frame_for_single_pane "false"

        mode_normal       "#[fg=#5f8787,bold] NORMAL "
        mode_locked       "#[fg=#999999,bold] LOCKED "
        mode_pane         "#[fg=#e78a53,bold] PANE "
        mode_tab          "#[fg=#e78a53,bold] TAB "
        mode_resize       "#[fg=#e78a53,bold] RESIZE "
        mode_scroll       "#[fg=#fbcb97,bold] SCROLL "
        mode_search       "#[fg=#fbcb97,bold] SEARCH "
        mode_entersearch  "#[fg=#fbcb97,bold] SEARCH "
        mode_renametab    "#[fg=#fbcb97,bold] RENAME "
        mode_renamepane   "#[fg=#fbcb97,bold] RENAME "
        mode_session      "#[fg=#e78a53,bold] SESSION "
        mode_move         "#[fg=#e78a53,bold] MOVE "
        mode_tmux         "#[fg=#e78a53,bold] TMUX "

        tab_normal              "#[fg=#777777] {index}·{name} "
        tab_normal_fullscreen   "#[fg=#777777] {index}·{name} F "
        tab_normal_sync         "#[fg=#777777] {index}·{name} S "
        tab_active              "#[fg=#121113,bg=#e78a53,bold] {index}·{name} "
        tab_active_fullscreen   "#[fg=#121113,bg=#e78a53,bold] {index}·{name} F "
        tab_active_sync         "#[fg=#121113,bg=#e78a53,bold] {index}·{name} S "
        tab_separator           " "

        datetime          "{format}"
        datetime_format   "%H:%M"
        datetime_timezone "Europe/London"
    }
}

// Web server on, sharing on — sessions are reachable at http://127.0.0.1:8082
// by default. Bound to loopback, so no remote exposure unless explicitly
// Tailscale-Served, in which case Tailscale handles HTTPS + auth.
web_server true
web_sharing "on"
web_server_ip "127.0.0.1"
web_server_port 8082
