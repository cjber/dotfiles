#!/usr/bin/env bash
# tv-toggle — bring the Hisense Frame TV up at 4K120 with sound on the soundbar,
# or drop it and send sound back to the desk. Bound to SUPER+SHIFT+T.
# ponytail: hardcoded sink/card names — they're stable PCI paths on this box;
# if the GPU/audio moves slot, update TV_SINK/DESK_SINK (see `pactl list short sinks`).

set -uo pipefail

LOCKFILE=/tmp/tv-toggle.lock
# flock — kernel-level advisory lock so two rapid toggles don't race.
# -w 3 = wait up to 3s for the lock; if a previous run was killed mid-flight
# the lock auto-releases (flock is FD-based, not file-based) so this only
# blocks during a genuine concurrent toggle. Background processes (wl-mirror,
# steam) must NOT inherit this FD — see {LOCK_FD}>&- on their launch lines.
exec {LOCK_FD}>"$LOCKFILE"
flock -w 3 "$LOCK_FD" || exit 0

TV=HDMI-A-1
TV_CARD=alsa_card.pci-0000_01_00.1
TV_SINK=alsa_output.pci-0000_01_00.1.hdmi-surround
DESK_SINK=alsa_output.pci-0000_0d_00.6.analog-stereo

move_streams() {  # move every active stream onto $1 so the switch is immediate
  pactl list short sink-inputs | cut -f1 | while read -r i; do
    [ -n "$i" ] && pactl move-sink-input "$i" "$1" 2>/dev/null
  done
}

if hyprctl monitors | grep -q "Monitor $TV"; then
  # TV is on -> pull its windows back to DP-1, drop the output, sound to desk
  # Kill wl-mirror first so DP-1 is fully restored
  pkill wl-mirror 2>/dev/null || true
  # Exit Steam Big Picture mode and close any running game windows on the TV
  hyprctl clients -j 2>/dev/null | jq -r '.[] | select(.title | test("Big Picture"; "i")) | .address' | while read -r addr; do
    [ -n "$addr" ] && hyprctl eval "hl.dispatch(hl.dsp.window.close({ window = \"$addr\" }))" 2>/dev/null
  done
  # Also close any steam_app game windows
  hyprctl clients -j 2>/dev/null | jq -r '.[] | select(.class | test("^steam_app_")) | .address' | while read -r addr; do
    [ -n "$addr" ] && hyprctl eval "hl.dispatch(hl.dsp.window.close({ window = \"$addr\" }))" 2>/dev/null
  done
  sleep 0.5  # let Steam finish exiting Big Picture
  # Pull remaining windows back from ws5 to DP-1
  hyprctl eval 'for _,w in ipairs(hl.get_workspace_windows(5) or {}) do hl.dispatch(hl.dsp.focus({ window = w })); hl.dispatch(hl.dsp.window.move({ workspace = 1 })) end' >/dev/null
  hyprctl eval "hl.monitor({ output=\"$TV\", disabled=true })" >/dev/null
  hyprctl eval 'hl.dispatch(hl.dsp.focus({ workspace = 1 }))' >/dev/null
  pactl set-card-profile "$TV_CARD" off
  sleep 0.3
  pactl set-default-sink "$DESK_SINK"
  move_streams "$DESK_SINK"
  notify-send -a tv "TV off" "windows → DP-1, audio → desk"
else
  # TV is off -> 4K120, open Steam Big Picture on ws5, sound to soundbar.
  hyprctl eval "hl.monitor({ output=\"$TV\", disabled=false, mode=\"3840x2160@119.88Hz\", position=\"4880x0\", scale=1.60 })" >/dev/null
  # Mirror the TV onto DP-1 so the game is visible from the desk
  wl-mirror --fullscreen-output DP-1 "$TV" {LOCK_FD}>&- >/dev/null 2>&1 &
  # Kill any running Steam first so it re-detects the TV at 4K instead of
  # reusing its cached 1600x900 Big Picture resolution from the desk monitor.
  pkill -f "steam" 2>/dev/null || true
  sleep 1
  steam steam://open/bigpicture {LOCK_FD}>&- >/dev/null 2>&1 &
  # Poll for the Big Picture window (title "Steam Big Picture Mode"), then send it to ws5.
  win=""
  for _ in $(seq 1 60); do  # ~15s: Big Picture is slow to map when Steam was in tray
    win=$(hyprctl clients -j | jq -r '.[] | select(.title|test("Big Picture";"i")) | .address' | head -1)
    [ -n "$win" ] && break
    sleep 0.25
  done
  [ -n "$win" ] && hyprctl eval "hl.dispatch(hl.dsp.focus({ window = \"$win\" })); hl.dispatch(hl.dsp.window.move({ workspace = 5 }))" >/dev/null
  hyprctl eval 'hl.dispatch(hl.dsp.focus({ workspace = 5 }))' >/dev/null
  pactl set-card-profile "$TV_CARD" output:hdmi-surround
  sleep 0.5  # let PipeWire create the sink before switching to it
  pactl set-default-sink "$TV_SINK"
  move_streams "$TV_SINK"
  notify-send -a tv "TV on — 4K120" "Big Picture → TV, audio → soundbar"
fi
